# ========================================
# LGMU Messenger Environment Configuration
# ========================================

# Server Configuration
PORT=5000
NODE_ENV=development
HOST=localhost

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/lgmu_messenger
MONGODB_USER=admin
MONGODB_PASSWORD=secure_password_123
MONGODB_AUTH_SOURCE=admin

# Redis Configuration (Optional, for caching)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Client Configuration
CLIENT_URL=http://localhost:3000
CLIENT_BUILD_PATH=./client/build

# File Upload Configuration
MAX_FILE_SIZE=52428800
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=image/*,video/*,audio/*,application/pdf,text/*
THUMBNAIL_SIZE=300x300
COMPRESSION_QUALITY=80

# Encryption Configuration
ENCRYPTION_KEY_ROTATION_HOURS=24
ENCRYPTION_ALGORITHM=aes-256-gcm
ENCRYPTION_KEY_SIZE=32

# Security Configuration
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:3000
HELMET_ENABLED=true

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=5

# Email Configuration (Optional, for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@lgmu-messenger.com

# Push Notifications (Optional)
FCM_SERVER_KEY=your-fcm-server-key
FCM_PROJECT_ID=your-fcm-project-id

# WebRTC Configuration
WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
WEBRTC_MAX_PEERS=10
WEBRTC_TIMEOUT=30000

# Monitoring Configuration
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=true
GRAFANA_PORT=3001

# Development Configuration
DEBUG=false
VERBOSE_LOGGING=false
ENABLE_SWAGGER=true
ENABLE_GRAPHQL_PLAYGROUND=false

# Production Configuration
SSL_ENABLED=false
SSL_CERT_PATH=
SSL_KEY_PATH=
FORCE_HTTPS=false

# Backup Configuration
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups

# Plugin System Configuration
PLUGINS_ENABLED=true
PLUGINS_PATH=./plugins
PLUGINS_AUTO_UPDATE=true
PLUGINS_VERIFICATION=true

# Bot System Configuration
BOTS_ENABLED=true
BOTS_PATH=./bots
BOTS_MAX_INSTANCES=100
BOTS_TIMEOUT=30000

# Internationalization
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,ru,de,fr,es,zh,ja,ko
LANGUAGE_DETECTION=true

# Performance Configuration
COMPRESSION_ENABLED=true
CACHE_ENABLED=true
CACHE_TTL=3600
MAX_CONCURRENT_REQUESTS=1000

# ========================================
# Environment-specific overrides
# ========================================

# Development overrides
# NODE_ENV=development
# LOG_LEVEL=debug
# DEBUG=true

# Production overrides
# NODE_ENV=production
# LOG_LEVEL=warn
# DEBUG=false
# SSL_ENABLED=true
# FORCE_HTTPS=true

# Testing overrides
# NODE_ENV=test
# MONGODB_URI=mongodb://localhost:27017/lgmu_messenger_test
# LOG_LEVEL=error
